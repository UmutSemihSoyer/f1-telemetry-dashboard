# ============================================================
# F1 2022 UDP Telemetry Dashboard — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Virtual Environment ---
venv/
env/
.venv/
.env

# --- Caches ---
.ergast_cache/
.pytest_cache/

# --- Databases & Logs ---
*.db
*.sqlite3
telemetry.db
fails.txt
test_results.txt

# --- Temporary / Dev Scratch Files ---
tr.txt
tr2.txt
tr3.txt
tr4.txt
read_docx_temp.py
verify_v7.py

# --- Generated Session Files (runtime outputs) ---
session_*.csv
session_*.pdf
test_export.pdf
live_data.json
braking_points.json
optimal_braking.json
competitors.json
alerts.json
engineer_feedback.json
best_lap_telemetry.json

# --- Unrelated / Accidental Directories ---
RedditApk/

# --- Spec Docs (large, not needed by users) ---
f1_2022_spec.txt
f1_2022_spec_utf8.txt

# --- Word Docs ---
*.docx

# --- Config (use config.example.json instead) ---
# config.json   <- intentionally tracked so the app works out of the box
